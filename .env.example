# Copy this file to ".env.local" and fill in real values.
# .env.local is gitignored — your keys stay private.

# Get a free API key at https://resend.com (Settings → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are emailed TO (your inbox).
CONTACT_TO_EMAIL=you@example.com

# The "from" address. Until you verify your own domain in Resend, you can use
# Resend's shared sender for testing: onboarding@resend.dev
CONTACT_FROM_EMAIL=onboarding@resend.dev
